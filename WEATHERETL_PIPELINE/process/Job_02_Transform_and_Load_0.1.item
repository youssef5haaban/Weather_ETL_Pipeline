      <outputTables sizeState="INTERMEDIATE" name="OUT_EnrichedRows">
        <mapperTableEntries name="city_name" expression="weather_cleaned.city_name " type="id_String" nullable="true"/>
        <mapperTableEntries name="city_code" expression="weather_cleaned.city_code " type="id_String" nullable="true"/>
        <mapperTableEntries name="forecast_dt" expression="weather_cleaned.forecast_dt " type="id_Date" nullable="true"/>
        <mapperTableEntries name="temp_celsius" expression="weather_cleaned.temp_celsius " type="id_Float" nullable="true"/>
        <mapperTableEntries name="feels_like_celsius" expression="weather_cleaned.feels_like_celsius " type="id_Float" nullable="true"/>
        <mapperTableEntries name="humidity_pct" expression="weather_cleaned.humidity_pct " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="pressure_hpa" expression="weather_cleaned.pressure_hpa " type="id_Float" nullable="true"/>
        <mapperTableEntries name="wind_speed_ms" expression="weather_cleaned.wind_speed_ms " type="id_Float" nullable="true"/>
        <mapperTableEntries name="weather_description" expression="weather_cleaned.weather_description " type="id_String" nullable="true"/>
        <mapperTableEntries name="cloud_cover_pct" expression="weather_cleaned.cloud_cover_pct " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="country" expression="cities_lookup.country " type="id_String" nullable="true"/>
        <mapperTableEntries name="region" expression="cities_lookup.region " type="id_String" nullable="true"/>
        <mapperTableEntries name="population_tier" expression="cities_lookup.population_tier " type="id_String" nullable="true"/>
        <mapperTableEntries name="utc_offset_hours" expression="cities_lookup.utc_offset_hours " type="id_Integer" nullable="true"/>
        <mapperTableEntries name="feels_like_delta" expression="(weather_cleaned.temp_celsius != null &amp;&amp; weather_cleaned.feels_like_celsius != null) ? (weather_cleaned.temp_celsius - weather_cleaned.feels_like_celsius) : 0.0f" type="id_Float" nullable="true"/>
        <mapperTableEntries name="humidity_category" expression="weather_cleaned.humidity_pct != null ? (weather_cleaned.humidity_pct > 70 ? &quot;High&quot; : &quot;Normal&quot;) : &quot;Unknown&quot;" type="id_String" nullable="true"/>
        <mapperTableEntries name="heat_index" expression="weather_cleaned.temp_celsius == null ? &quot;UNKNOWN&quot; : &#xA;(weather_cleaned.temp_celsius &lt; 15 ? &quot;COLD&quot; : &#xA;(weather_cleaned.temp_celsius &lt;= 25 ? &quot;MILD&quot; : &quot;HOT&quot;))" type="id_String" nullable="true"/>
        <mapperTableEntries name="data_quality_flag" expression="(weather_cleaned.humidity_pct  > 95 &amp;&amp; cities_lookup.region  == null) ? &quot;High humidity – no region match&quot; : (TalendDate.diffDate(weather_cleaned.forecast_dt , TalendDate.getCurrentDate(), &quot;dd&quot;) > 6) ? &quot;Forecast beyond 5-day window&quot; : &quot;&quot;" type="id_String" nullable="true"/>
        <mapperTableEntries name="is_rejected" expression="(weather_cleaned.temp_celsius &lt; -80 || weather_cleaned.temp_celsius > 60) || (weather_cleaned.city_code == null)" type="id_Boolean" nullable="true"/>
      </outputTables>
      <inputTables sizeState="INTERMEDIATE" name="weather_cleaned" matchingMode="UNIQUE_MATCH" lookupMode="LOAD_ONCE">
