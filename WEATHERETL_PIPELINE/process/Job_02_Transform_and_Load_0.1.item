        <mapperTableEntries name="cloud_cover_pct" type="id_Integer" nullable="true"/>
      </inputTables>
      <inputTables sizeState="INTERMEDIATE" name="cities_lookup" matchingMode="UNIQUE_MATCH" lookupMode="LOAD_ONCE" persistent="true">
